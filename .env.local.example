# =============================================================================
# PRODUCCIÓN — Firebase + Vercel (recomendado)
# =============================================================================
# En Vercel: Project → Settings → Environment Variables → agregá cada clave
# (mismos nombres que acá). NO uses build:static en Vercel: el repo tiene vercel.json con npm run build.
#
# 1) Completá Firebase (consola → Configuración del proyecto → Tus apps).
# 2) Quitá o no definas NEXT_PUBLIC_COPALIBERO_DEMO en producción.
# 3) Firestore: colección "admins", documento ID = UID del usuario (Auth).
# 4) Reglas: firebase/firestore.rules

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional. Si no definís nada, la app usa proyecto.appspot.com como storageBucket
# (evita el error con *.firebasestorage.app en algunos proyectos Spark). No pongas la URL
# *.firebasestorage.app acá.
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# --- Solo desarrollo / preview con datos de prueba (no en Vercel Production) ---
# NEXT_PUBLIC_COPALIBERO_DEMO=1

# =============================================================================
# Sitio estático (GitHub Pages, etc.) — sin Firebase en vivo
# =============================================================================
# Build: npm run build:static (no hace falta pegar variables: el script pone STATIC_EXPORT)

# =============================================================================
# Cloudflare D1 (sin Firebase)
# =============================================================================
# NEXT_PUBLIC_COPALIBERO_BACKEND=d1
# En preview local OpenNext: SESSION_SECRET en .dev.vars

# Cloudflare Workers (OpenNext): mismas NEXT_PUBLIC_* en el dashboard del Worker.
# Build + deploy: npm run deploy:cf
# Si ves "Could not find compiled Open Next config" → el build no corrió antes del deploy.
