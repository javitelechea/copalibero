# --- Publicar SOLO demo (sin Firebase): dejá las de Firebase vacías y usá solo esta línea ---
NEXT_PUBLIC_COPALIBERO_DEMO=1

# --- Producción: completá las de Firebase y quitá o desactivá COPALIBERO_DEMO ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Cloudflare: en el dashboard (Workers build / Variables) copiá las mismas NEXT_PUBLIC_* que en .env.local
#
# Si ves: "Could not find compiled Open Next config" → el build NO corrió antes del deploy.
# En Cloudflare (Build command), usá UNA línea que haga build + deploy:
#   npm ci && npx opennextjs-cloudflare build && npx opennextjs-cloudflare deploy
# (o local: npm run deploy:cf  tras npm ci)
