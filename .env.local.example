# --- Sitio estático (subir carpeta `out/` a Cloudflare Pages, Netlify, etc.) ---
# Solo datos demo, sin Firebase ni D1. Build: npm run build:static
# (no hace falta agregar variables: el script ya pasa NEXT_PUBLIC_COPALIBERO_STATIC_EXPORT=1)

# --- Cloudflare D1 (sin Firebase): API en /api/copalibero + binding DB en wrangler ---
# NEXT_PUBLIC_COPALIBERO_BACKEND=d1
# En local con opennext preview: SESSION_SECRET en .dev.vars (no NEXT_PUBLIC)
# SESSION_SECRET=poné_un_secreto_largo_de_al_menos_16_caracteres

# --- Publicar SOLO demo (sin Firebase): dejá las de Firebase vacías y usá solo esta línea ---
NEXT_PUBLIC_COPALIBERO_DEMO=1

# --- Producción: completá las de Firebase y quitá o desactivá COPALIBERO_DEMO ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional. Si no definís nada, la app usa proyecto.appspot.com como storageBucket
# (evita el error con *.firebasestorage.app en algunos proyectos Spark). No pongas la URL
# *.firebasestorage.app acá.
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Cloudflare: en el dashboard (Workers build / Variables) copiá las mismas NEXT_PUBLIC_* que en .env.local
#
# Si ves: "Could not find compiled Open Next config" → el build NO corrió antes del deploy.
# En Cloudflare (Build command), usá UNA línea que haga build + deploy:
#   npm ci && npx opennextjs-cloudflare build && npx opennextjs-cloudflare deploy
# (o local: npm run deploy:cf  tras npm ci)
