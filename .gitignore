# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
copalibero-static-site.zip
.open-next/
.wrangler-home/

# production
/build

# local npm cache (CI / sandbox)
.npm-cache/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (no subir secretos; la plantilla sí va al repo)
.env*
!.env.local.example

# Cuenta de servicio Firebase (solo local, para npm run seed:players)
firebase-service-account.local.json

# vercel
.vercel

# wrangler local secrets (never commit these)
.dev.vars

# si falla `npm run build:static` a mitad, puede quedar el backup de API
src/.static_export_api_bak

# typescript
*.tsbuildinfo
next-env.d.ts
