# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (no subir secretos; la plantilla sí va al repo)
.env*
!.env.local.example

# Cuenta de servicio Firebase (solo local, para npm run seed:players)
firebase-service-account.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
