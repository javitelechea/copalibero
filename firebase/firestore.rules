rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /players/{playerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /matches/{matchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /match_players/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /match_goals/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /match_confirmations/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /asados/{asadoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /asado_players/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
